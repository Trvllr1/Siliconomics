    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.26",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.25.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.2.3",
    "vitest": "^4.1.10"
  }
