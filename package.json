{
  "name": "siliconomics",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx server.ts",
    "dev:api": "npx vercel dev",
    "build": "vite build",
    "start": "npx vercel --prod",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "chippie:knowledge": "node scripts/generateChippieKnowledge.mjs",
    "lint": "eslint . && tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "deploy": "npx vercel --prod"
  },
  "dependencies": {
    "@clerk/clerk-react": "^5.61.9",
    "@clerk/types": "^4.101.26",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-query": "^5.101.2",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^4.17.21",
