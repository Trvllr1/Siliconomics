{
  "nodeVersion": "22.x",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "devCommand": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/*.ts": {
      "runtime": "@vercel/node@4.0.0"
    }
  },
  "github": {
    "silent": true
  }
}
