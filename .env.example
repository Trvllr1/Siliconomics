# NIM_API_KEY: NVIDIA NIM API key for Chippie (the embedded advisor).
# Optional — Chippie runs in demo fallback mode when absent.
NIM_API_KEY="MY_NIM_API_KEY"

# CHIPPIE_BASE_URL / CHIPPIE_MODEL: NIM endpoint overrides (optional).
# CHIPPIE_BASE_URL="https://integrate.api.nvidia.com/v1"
# CHIPPIE_MODEL="meta/llama-3.1-8b-instruct"

# VITE_FOUNDER_MODE: set to "true" to enable Chippie's founder-only GTM
# advisory tools (drafts only — every asset requires founder sign-off).
# VITE_FOUNDER_MODE="true"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
